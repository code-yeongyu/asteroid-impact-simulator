{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "asteroid-impact-simulator",
  "compatibility_date": "2026-04-28",
  "main": "worker/index.ts",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
