[
  {
    "name": "Initial JS",
    "path": "dist/client/assets/entry.client-*.js",
    "limit": "115 KB",
    "gzip": true
  },
  {
    "name": "KaTeX chunk (lazy)",
    "path": "dist/client/assets/katex-*.js",
    "limit": "80 KB",
    "gzip": true
  },
  {
    "name": "Methodology route",
    "path": "dist/client/assets/*.methodology-*.js",
    "limit": "10 KB",
    "gzip": true
  },
  {
    "name": "Privacy route",
    "path": "dist/client/assets/*.privacy-*.js",
    "limit": "5 KB",
    "gzip": true
  },
  {
    "name": "Simulator route",
    "path": "dist/client/assets/*.simulator-*.js",
    "limit": "5 KB",
    "gzip": true
  },
  {
    "name": "Per-locale JSON",
    "path": "dist/client/locales/**/*.json",
    "limit": "10 KB",
    "gzip": false
  }
]
