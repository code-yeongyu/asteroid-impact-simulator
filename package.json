{
  "name": "asteroid-impact-simulator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:lhci": "lhci autorun",
    "test:a11y": "playwright test --project=a11y",
    "test:budget": "size-limit",
    "test:i18n-coverage": "echo 'i18n coverage placeholder'",
    "test:all": "bun run typecheck && bun run lint && bun run test:unit && bun run test:e2e && bun run test:lhci && bun run test:a11y && bun run test:budget && bun run test:i18n-coverage"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0",
    "@react-router/fs-routes": "^7.0.0",
    "@base-ui/react": "^1.4.1",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "i18next": "^26.0.3",
    "react-i18next": "^15.0.0",
    "i18next-http-backend": "^3.0.0",
    "i18next-icu": "^2.0.0",
    "i18next-resources-to-backend": "^1.2.0",
    "i18next-chained-backend": "^4.6.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "intl-messageformat": "^10.5.0",
    "zustand": "^5.0.0",
    "zustand-computed": "^2.1.0",
    "react-hook-form": "^7.71.0",
    "@hookform/resolvers": "^5.0.0",
    "zod": "^4.0.0",
    "maplibre-gl": "^5.23.0",
    "react-map-gl": "^8.1.0",
    "recharts": "^3.8.0",
    "@visx/scale": "^3.5.0",
    "@visx/shape": "^3.5.0",
    "@visx/axis": "^3.5.0",
    "@visx/grid": "^3.5.0",
    "@visx/responsive": "^3.5.0",
    "@react-three/fiber": "^9.6.0",
    "@react-three/drei": "^10.7.7",
    "three": "^0.170.0",
    "simplex-noise": "^4.0.0",
    "katex": "^0.16.0",
    "react-helmet-async": "^2.0.0",
    "@phosphor-icons/react": "^2.1.0",
    "@turf/circle": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "vite": "^7.0.0",
    "@react-router/dev": "^7.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "wrangler": "^4.85.0",
    "@cloudflare/vite-plugin": "^1.7.0",
    "typescript": "^5.6.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-i18next": "^6.1.0",
    "globals": "^15.0.0",
    "prettier": "^3.4.0",
    "vitest": "^3.0.0",
    "@vitest/ui": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "jsdom": "^26.0.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@playwright/test": "^1.50.0",
    "@axe-core/playwright": "^4.10.0",
    "@lhci/cli": "^0.14.0",
    "size-limit": "^11.1.0",
    "@size-limit/preset-app": "^11.1.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "sharp": "^0.34.0",
    "fontmin": "^2.0.0",
    "i18next-parser": "^9.0.0",
    "husky": "^9.1.0",
    "lint-staged": "^16.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
